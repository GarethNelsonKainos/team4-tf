# Local .terraform directory (downloaded providers/modules)
.terraform/

# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output
*.tfplan

# Variable files with real values — may contain secrets
*.tfvars
*.tfvars.json

# Override files (local dev overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log
crash.log
crash.*.log

# Lock file is safe to commit (it pins provider versions)
# !.terraform.lock.hcl
